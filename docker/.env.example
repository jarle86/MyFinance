# MyFinance Docker Environment
# Copy this file to .env and configure

# Database
DB_USER=myfinance
DB_PASSWORD=myfinance
DB_NAME=myfinance
DB_HOST=localhost
DB_PORT=5432

# LLM (Ollama proxy)
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=dummy

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token

# Streamlit
STREAMLIT_PORT=8501
